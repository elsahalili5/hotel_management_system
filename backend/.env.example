# mariadb:// or mysql:// (adapter rewrites mysql → mariadb).
# Empty password: use USER@HOST, not USER:@HOST — the driver rejects the latter.
# With password: USER:PASSWORD@HOST. Encode special chars in USER/PASSWORD.
# MySQL 8 auth: add ?allowPublicKeyRetrieval=true
#
# DATABASE_URL="mariadb://root:secret@127.0.0.1:3306/mansio_db?allowPublicKeyRetrieval=true"
# DATABASE_URL="mariadb://root@127.0.0.1:3306/mansio_db"

DATABASE_URL="mariadb://USER@localhost:3306/DATABASE"
