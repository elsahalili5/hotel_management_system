
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  PENDING
  ACTIVE
  LOCKED
  DISABLED
}

enum TokenType {
  REFRESH
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum Shift {
  MORNING
  AFTERNOON
  NIGHT
}

model User {
  id                  Int        @id @default(autoincrement())
  first_name          String
  last_name           String
  email               String     @unique
  password_hash       String
  status              UserStatus @default(PENDING)

  lockout_enabled     Boolean    @default(true)
  access_failed_count Int        @default(0)
  email_confirmed     Boolean    @default(false)

  created_at          DateTime   @default(now())

  staff_profile       Staff?
  guest_profile       Guest?
  user_roles          UserRole[]
  user_tokens         UserTokens[]
  refresh_tokens RefreshTokens[]
}


model Role {
  id              Int        @id @default(autoincrement())
  name            String     @unique
  normalized_name String     @unique
  description     String?
  user_roles      UserRole[]
}

model UserRole {
  user_id Int
  role_id Int
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role    Role @relation(fields: [role_id], references: [id])

  @@id([user_id, role_id])
}

model Staff {
  id           Int     @id @default(autoincrement())
  phone_number String?
  shift        Shift   @default(MORNING)
  is_active    Boolean @default(true)

  user_id      Int     @unique
  user         User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Guest {
  id              Int       @id @default(autoincrement())
  phone_number    String?
  address         String?
  city            String?
  country         String?
  passport_number String?   @unique
  date_of_birth   DateTime?

  user_id         Int       @unique
  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  reservations    Reservation[]
}

model Reservation {
  id       Int   @id @default(autoincrement())
  guest_id Int
  guest    Guest @relation(fields: [guest_id], references: [id])
}
model RoomType {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  description   String?           @db.Text
  base_price    Decimal           @db.Decimal(10, 2)
  max_occupancy Int
  size_m2       Int?
  
  rooms         Room[]
  amenities     RoomTypeAmenity[]
  beds          RoomTypeBed[]
  images        RoomImage[]
}

model Room {
  id           Int        @id @default(autoincrement())
  room_number  String     @unique
  floor        Int
  status       RoomStatus @default(AVAILABLE)
  
  room_type_id Int
  room_type    RoomType   @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
}

model RoomImage {
  id           Int      @id @default(autoincrement())
  url          String   @db.Text
  is_primary   Boolean  @default(false)
  alt_text     String?
  
  room_type_id Int
  room_type    RoomType @relation(fields: [room_type_id], references: [id], onDelete: Cascade)
}

model Amenity {
  id         Int               @id @default(autoincrement())
  name       String            @unique
  icon       String?
  room_types RoomTypeAmenity[]
}

model RoomTypeAmenity {
  room_type_id Int
  amenity_id   Int
  
  room_type    RoomType @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  amenity      Amenity  @relation(fields: [amenity_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  
  @@id([room_type_id, amenity_id])
}

model Bed {
  id         Int           @id @default(autoincrement())
  name       String        @unique
  capacity   Int
  room_types RoomTypeBed[]
}

model RoomTypeBed {
  room_type_id Int
  bed_id       Int
  quantity     Int         @default(1)
  
  room_type    RoomType @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bed          Bed      @relation(fields: [bed_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  
  @@id([room_type_id, bed_id])
}
model RefreshTokens {
  id        Int      @id @default(autoincrement())
  user_id   Int
  token     String   @unique
  expires   DateTime
  created   DateTime @default(now())
  revoked   Boolean  @default(false)

  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model UserTokens {
  id              Int      @id @default(autoincrement())
  user_id         Int
  login_provider  String
  token_name      String
  token_value     String
  created_at      DateTime @default(now())

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}