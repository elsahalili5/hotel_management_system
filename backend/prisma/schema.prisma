
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserStatus {
  PENDING
  ACTIVE
  LOCKED
  DISABLED
}

enum TokenType {
  REFRESH
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum Shift {
  MORNING
  AFTERNOON
  NIGHT
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  CLEANING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ReservationStatus {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum ServiceOrderStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  ISSUED
  PAID
  CANCELLED
}

enum PaymentStatus {
  COMPLETED
}

enum PaymentMethod {
  CASH
  CARD
}

// ─────────────────────────────────────────
// USERS & ROLES
// ─────────────────────────────────────────

model User {
  id                  Int        @id @default(autoincrement())
  first_name          String
  last_name           String
  email               String     @unique
  password_hash       String
  status              UserStatus @default(PENDING)

  lockout_enabled     Boolean    @default(true)
  access_failed_count Int        @default(0)
  locked_until        DateTime?
  email_confirmed     Boolean    @default(false)

  created_at          DateTime   @default(now())

  staff_profile       Staff?
  guest_profile       Guest?
  user_roles          UserRole[]
  user_tokens         UserTokens[]
  refresh_tokens      RefreshTokens[]
  assigned_tasks      CleaningTask[]  @relation("ManagerAssignments")
}

model Role {
  id              Int        @id @default(autoincrement())
  name            String     @unique
  normalized_name String     @unique
  description     String?
  user_roles      UserRole[]
}

model UserRole {
  user_id Int
  role_id Int
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role    Role @relation(fields: [role_id], references: [id])

  @@id([user_id, role_id])
}

// ─────────────────────────────────────────
// STAFF & GUEST PROFILES
// ─────────────────────────────────────────

model Staff {
  id           Int     @id @default(autoincrement())
  phone_number String?
  shift        Shift   @default(MORNING)
  is_active    Boolean @default(true)

  user_id      Int     @unique
  user         User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cleaning_tasks CleaningTask[] @relation("StaffCleaningTasks")
  service_orders ServiceOrders[]
}

model Guest {
  id              Int       @id @default(autoincrement())
  phone_number    String?
  address         String?
  city            String?
  country         String?
  passport_number String?   @unique
  date_of_birth   DateTime?

  user_id         Int       @unique
  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  reservations    Reservation[]
  reviews         Review[]
}

// ─────────────────────────────────────────
// TOKEN MANAGEMENT
// ─────────────────────────────────────────

model RefreshTokens {
  id        Int      @id @default(autoincrement())
  user_id   Int
  token     String   @unique
  expires   DateTime
  created   DateTime @default(now())
  revoked   Boolean  @default(false)

  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model UserTokens {
  id              Int      @id @default(autoincrement())
  user_id         Int
  login_provider  String
  token_name      String
  token_value     String
  created_at      DateTime @default(now())

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// ROOMS
// ─────────────────────────────────────────

model RoomType {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  description   String?           @db.Text
  base_price    Decimal           @db.Decimal(10, 2)
  max_occupancy Int
  size_m2       Int?

  rooms         Room[]
  amenities     RoomTypeAmenity[]
  beds          RoomTypeBed[]
  images        RoomImage[]
}

model Room {
  id           Int        @id @default(autoincrement())
  room_number  String     @unique
  floor        Int
  status       RoomStatus @default(AVAILABLE)

  room_type_id Int
  room_type    RoomType   @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cleaning_tasks CleaningTask[]
  reservations   Reservation[]
}

model RoomImage {
  id           Int      @id @default(autoincrement())
  url          String   @db.Text
  is_primary   Boolean  @default(false)
  alt_text     String?

  room_type_id Int
  room_type    RoomType @relation(fields: [room_type_id], references: [id], onDelete: Cascade)
}

model Amenity {
  id         Int               @id @default(autoincrement())
  name       String            @unique
  icon       String?
  room_types RoomTypeAmenity[]
}

model RoomTypeAmenity {
  room_type_id Int
  amenity_id   Int

  room_type    RoomType @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  amenity      Amenity  @relation(fields: [amenity_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([room_type_id, amenity_id])
}

model Bed {
  id         Int           @id @default(autoincrement())
  name       String        @unique
  capacity   Int
  room_types RoomTypeBed[]
}

model RoomTypeBed {
  room_type_id Int
  bed_id       Int
  quantity     Int      @default(1)

  room_type    RoomType @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bed          Bed      @relation(fields: [bed_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([room_type_id, bed_id])
}

// ─────────────────────────────────────────
// CLEANING
// ─────────────────────────────────────────

model CleaningTask {
  id             Int        @id @default(autoincrement())
  room_id        Int
  staff_id       Int
  assigned_by_id Int
  status         TaskStatus @default(PENDING)
  due_date       DateTime?
  notes          String?    @db.Text
  assigned_at    DateTime   @default(now())
  finished_at    DateTime?

  room        Room  @relation(fields: [room_id], references: [id])
  staff       Staff @relation("StaffCleaningTasks", fields: [staff_id], references: [id])
  assigned_by User  @relation("ManagerAssignments", fields: [assigned_by_id], references: [id])
}

// ─────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────

model ServiceCategory {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  sort_order  Int            @default(0)
  is_active   Boolean        @default(true)

  services    ExtraService[]
}

model ExtraService {
  id               Int             @id @default(autoincrement())
  name             String
  description      String?         @db.Text
  price            Decimal         @db.Decimal(10, 2)
  is_active        Boolean         @default(true)
  is_available_24h Boolean         @default(false)
  available_from   String?
  available_until  String?
  category_id      Int

  category         ServiceCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  orders           ServiceOrders[]
}

// ─────────────────────────────────────────
// MEAL PLANS
// ─────────────────────────────────────────

model MealPlan {
  id              Int     @id @default(autoincrement())
  name            String  @unique
  description     String? @db.Text
  price_per_night Decimal @db.Decimal(10, 2)
  is_active       Boolean @default(true)

  reservations    Reservation[]
}

// ─────────────────────────────────────────
// RESERVATION
// ─────────────────────────────────────────

model Reservation {
  id               Int               @id @default(autoincrement())
  guest_id         Int
  room_id          Int
  meal_plan_id     Int?
  status           ReservationStatus @default(CONFIRMED)
  check_in_date    DateTime
  check_out_date   DateTime
  adults           Int               @default(1)
  children         Int               @default(0)

  checked_in_at    DateTime?
  checked_in_by    Int?
  check_in_notes   String?           @db.Text

  checked_out_at   DateTime?
  checked_out_by   Int?
  check_out_notes  String?           @db.Text

  created_at       DateTime          @default(now())

  guest            Guest         @relation(fields: [guest_id], references: [id], onDelete: Cascade)
  room             Room          @relation(fields: [room_id], references: [id])
  meal_plan        MealPlan?     @relation(fields: [meal_plan_id], references: [id], onDelete: SetNull)
  orders           ServiceOrders[]
  invoice          Invoice?
  review           Review?
}

// ─────────────────────────────────────────
// SERVICE ORDERS
// ─────────────────────────────────────────

model ServiceOrders {
  id               Int                @id @default(autoincrement())
  reservation_id   Int
  service_id       Int
  quantity         Int                @default(1)
  unit_price       Decimal            @db.Decimal(10, 2)
  notes            String?            @db.Text
  scheduled_at     DateTime?
  ordered_at       DateTime           @default(now())
  status           ServiceOrderStatus @default(PENDING)
  ordered_by_guest Boolean            @default(false)
  staff_id         Int?

  reservation      Reservation  @relation(fields: [reservation_id], references: [id])
  service          ExtraService @relation(fields: [service_id], references: [id])
  staff            Staff?       @relation(fields: [staff_id], references: [id])
  invoice_item     InvoiceItem?
}

// ─────────────────────────────────────────
// INVOICE & PAYMENT
// ─────────────────────────────────────────

model Invoice {
  id             Int           @id @default(autoincrement())
  reservation_id Int           @unique
  status         InvoiceStatus @default(ISSUED)
  notes          String?       @db.Text
  issued_at      DateTime?
  due_date       DateTime?
  created_at     DateTime      @default(now())

  reservation    Reservation @relation(fields: [reservation_id], references: [id])
  items          InvoiceItem[]
  payments       Payment[]
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoice_id  Int
  description String
  quantity    Int      @default(1)
  unit_price  Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  order_id    Int?     @unique

  invoice     Invoice        @relation(fields: [invoice_id], references: [id])
  orders      ServiceOrders? @relation(fields: [order_id], references: [id])
}

model Payment {
  id         Int           @id @default(autoincrement())
  invoice_id Int
  amount     Decimal       @db.Decimal(10, 2)
  method     PaymentMethod
  status     PaymentStatus @default(COMPLETED)
  notes      String?
  paid_at    DateTime      @default(now())

  invoice    Invoice       @relation(fields: [invoice_id], references: [id])
}

// ─────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────

model Review {
  id             Int      @id @default(autoincrement())
  guest_id       Int
  reservation_id Int      @unique
  rating         Int
  title          String?
  comment        String?  @db.Text
  is_approved    Boolean  @default(false)
  created_at     DateTime @default(now())

  guest          Guest       @relation(fields: [guest_id], references: [id], onDelete: Cascade)
  reservation    Reservation @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
}
